{
  "id": "/",
  "name": "orvuex ai",
  "short_name": "orvuex",
  "description": "Interface de chat IA moderne côté client (BYOK)",
  "theme_color": "#09090b",
  "background_color": "#09090b",
  "display": "standalone",
  "display_override": [
    "tabbed",
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "lang": "fr-FR",
  "dir": "ltr",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.orvuex.ai",
      "id": "com.orvuex.ai"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/orvuex-ai/id123456789"
    }
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "scope_extensions": [
    {
      "origin": "https://orvuex-ai.vercel.app"
    },
    {
      "origin": "https://ais-dev-e4e7qexcss4oe4ts3q2r75-405902477635.europe-west2.run.app"
    },
    {
      "origin": "https://ais-pre-e4e7qexcss4oe4ts3q2r75-405902477635.europe-west2.run.app"
    }
  ],
  "start_url": "/",
  "scope": "/",
  "orientation": "portrait",
  "categories": [
    "productivity",
    "utilities",
    "education"
  ],
  "icons": [
    {
      "src": "/pwa-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/pwa-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/pwa-maskable-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Interface de chat sur Bureau"
    },
    {
      "src": "/screenshot-mobile.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Interface de chat sur Mobile"
    }
  ],
  "shortcuts": [
    {
      "name": "Nouveau Chat",
      "short_name": "Nouveau Chat",
      "description": "Commencer une nouvelle conversation de chat",
      "url": "/",
      "icons": [
        {
          "src": "/pwa-192x192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "file_handlers": [
    {
      "action": "/?file=1",
      "accept": {
        "text/plain": [".txt"],
        "application/json": [".json"],
        "text/markdown": [".md"]
      },
      "icons": [
        {
          "src": "/pwa-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "protocol_handlers": [
    {
      "protocol": "web+orvuex",
      "url": "/?url=%s"
    },
    {
      "protocol": "web+chat",
      "url": "/?chat=%s"
    }
  ],
  "share_target": {
    "action": "/?share=1",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "widgets": [
    {
      "name": "orvuex ai Widget",
      "short_name": "orvuex",
      "description": "Accès rapide aux fonctionnalités de chat d'orvuex ai.",
      "tag": "chat-widget",
      "template": "chat-widget",
      "ms_ac_template": "widgets/chat-widget.json",
      "icons": [
        {
          "src": "/pwa-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "screenshots": [
        {
          "src": "/screenshot-mobile.png",
          "sizes": "1080x1920",
          "type": "image/png",
          "label": "Aperçu du widget orvuex ai"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "tab_strip": {
    "home_tab": {
      "scope": "/"
    },
    "new_tab_button": {
      "url": "/"
    }
  },
  "note_taking": {
    "new_note_url": "/?note=new"
  }
}
